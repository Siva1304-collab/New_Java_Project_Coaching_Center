<tomcat-users xmlns="http://tomcat.apache.org/xml"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://tomcat.apache.org/xml tomcat-users.xsd"
              version="1.0">

    <!--
      NOTE:  By default, no user is included in the "manager-gui" role required
      to operate the "/manager/html" web application.  If you wish to use this app,
      you must define such a user - the username and password are arbitrary.

      NOTE:  The sample user and role entries below are intended for use with the
      examples web application. They are wrapped in a comment and thus are ignored
      when reading this file. Do not forget to remove <![CDATA[ and ]]> tags to
      use them.
    -->

    <!-- Roles Definitions -->
    <role rolename="admin"/>
    <role rolename="manager"/>
    <role rolename="manager-gui"/>
    <role rolename="manager-script"/>
    <role rolename="manager-jmx"/>
    <role rolename="manager-status"/>
    <role rolename="tomcat"/>
    <role rolename="role1"/>
    <role rolename="user"/>

    <!-- User Definitions for Coaching Center Application -->
    
    <!-- Administrator - Full access to all features -->
    <user username="admin" 
          password="admin123" 
          roles="admin,manager,manager-gui,manager-script,manager-jmx,manager-status"/>
    
    <!-- Manager - Can manage students and view reports -->
    <user username="manager" 
          password="manager123" 
          roles="admin,manager,manager-gui"/>
    
    <!-- Staff - Limited access (view and add students only) -->
    <user username="staff" 
          password="staff123" 
          roles="user"/>
    
    <!-- Read-only User - Can only view data -->
    <user username="viewer" 
          password="viewer123" 
          roles="tomcat"/>

    <!-- Development Users -->
    <user username="dev" 
          password="dev123" 
          roles="admin,manager-gui,manager-script"/>
    
    <!-- Production Users -->
    <user username="prod_admin" 
          password="Prod@2024Secure!" 
          roles="admin,manager-gui"/>

    <!-- Sample users (commented by default, uncomment to use) 
    <user username="tomcat" password="tomcat" roles="tomcat"/>
    <user username="both" password="tomcat" roles="tomcat,role1"/>
    <user username="role1" password="tomcat" roles="role1"/>
    -->

    <!-- Additional Configuration for Web Application Manager -->
    <!-- This allows access to the manager application for deployment -->
    <user username="deployer" 
          password="deploy@2024" 
          roles="manager-script,manager-gui"/>

    <!-- User for Database Connection Pool Monitoring -->
    <user username="monitor" 
          password="monitor123" 
          roles="manager-status"/>

    <!-- LDAP Integration Example (commented)
    <role rolename="ldap-admin"/>
    <role rolename="ldap-user"/>
    <user username="ldapuser" password="ldappass" roles="ldap-user"/>
    -->
    
    <!-- Note: For production environments, always use strong passwords and 
         consider using encrypted password storage with UserDatabase realm -->
</tomcat-users>
